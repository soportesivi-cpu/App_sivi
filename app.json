{
  "expo": {
    "name": "Sivi",
    "slug": "AliceGuardianApp",
    "scheme": "aliceguardian",
    "version": "1.2",
    "orientation": "portrait",
    "icon": "./assets/icon-sivi.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./bg-grande.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-sivi-adaptive.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.soportesivi.AliceGuardianApp",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bdfb1d9a-7bc0-4572-abeb-42ea39601301"
      }
    },
    "owner": "sivisoporte"
  }
}